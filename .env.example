# =============================================================================
# Oui Smoke — environment variables
# Copy to .env.local for local dev, or set in Vercel → Project → Settings → Env.
# Never commit real secrets. NEXT_PUBLIC_* values are exposed to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# Site / URLs
# -----------------------------------------------------------------------------

# Canonical public origin (no trailing slash). Used for emails, guest/QR links,
# Square redirect + webhook notification URL, SEO metadataBase, push deep links.
# Falls back to VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL when unset.
NEXT_PUBLIC_SITE_URL=https://ouismoke.co

# -----------------------------------------------------------------------------
# Ops auth (required for admin)
# -----------------------------------------------------------------------------

# JWT signing secret for ops sessions. Prefer a long random value in production.
# If unset, falls back to OPS_PASSWORD (warned in production).
OPS_SESSION_SECRET=generate-a-long-random-string

# Bootstrap password for the first admin when no ops_users exist yet.
# Also used as legacy “ops” login and as OPS_SESSION_SECRET fallback.
OPS_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Database (required for app + migrations)
# -----------------------------------------------------------------------------

# Neon Postgres connection string (also used by drizzle-kit / scripts/migrate-*).
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# -----------------------------------------------------------------------------
# Email — Resend (optional; emails no-op if RESEND_API_KEY is missing)
# -----------------------------------------------------------------------------

# Resend API key. Without it, booking/ops/password-reset mail is skipped.
RESEND_API_KEY=

# From header (outbound). Domain is verified for sending via Resend.
# Default: Oui Smoke <contact@ouismoke.co>
RESEND_FROM=Oui Smoke <contact@ouismoke.co>

# Ops inbox for password-reset magic links, booking alerts, reply-to.
# Alias: RESEND_OPS_EMAIL (legacy). Default: contact@ouismoke.co
# @oohstack.com addresses are blocked and rewritten to the default.
OPS_NOTIFY_EMAIL=contact@ouismoke.co
# RESEND_OPS_EMAIL=

# -----------------------------------------------------------------------------
# Blob storage — guest / job photos (optional until uploads are used)
# -----------------------------------------------------------------------------

# Vercel Blob read/write token. Auto-injected when a Blob store is linked on
# Vercel; set locally if testing photo upload/delete.
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Square payments (optional until deposit/balance links are needed)
# -----------------------------------------------------------------------------

# Square API access token + location for payment links / Terminal.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# Paired Square Terminal device id (Dashboard → Terminal / Device codes).
# Enables “Collect on Terminal” for deposits, balances, and guest unit pay.
SQUARE_TERMINAL_DEVICE_ID=

# sandbox | production — selects Square API host. Default: sandbox
SQUARE_ENVIRONMENT=sandbox

# Webhook signature key from Square Dashboard → Webhooks.
# Subscribe to payment.* and terminal.checkout.updated.
# Without it, webhooks only process if SQUARE_WEBHOOK_SKIP_VERIFY=1.
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Dev-only: allow unsigned Square webhooks when signature key is unset.
# Never enable in production. Set to 1 to skip verify.
# SQUARE_WEBHOOK_SKIP_VERIFY=

# -----------------------------------------------------------------------------
# Web push (optional; staff push skipped if keys missing)
# -----------------------------------------------------------------------------

# VAPID key pair (generate with web-push). Public key is sent to the browser.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Contact subject for VAPID. Default: mailto:contact@ouismoke.co
VAPID_SUBJECT=mailto:contact@ouismoke.co

# -----------------------------------------------------------------------------
# Cron
# -----------------------------------------------------------------------------

# Bearer token for /api/cron/payment-reminders (daily auto balance sweep).
# Vercel Cron sends Authorization: Bearer <CRON_SECRET> when this is set.
CRON_SECRET=

# -----------------------------------------------------------------------------
# Platform (set automatically — do not put secrets here)
# -----------------------------------------------------------------------------

# NODE_ENV                 — development | production | test (Node/Next)
# VERCEL_URL               — preview/deployment host (no scheme); URL fallback
# VERCEL_PROJECT_PRODUCTION_URL — production host; preferred URL fallback
