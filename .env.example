# Public site origin used for absolute links, emails, and SEO metadataBase fallbacks.
NEXT_PUBLIC_SITE_URL=https://ouismoke.co

# Ops auth
# Required for JWT sessions in production (falls back to OPS_PASSWORD if unset).
OPS_SESSION_SECRET=generate-a-long-random-string
# Bootstrap first admin + legacy session fallback.
OPS_PASSWORD=change-me

# Database
# DATABASE_URL=

# Email (Resend) — password-reset magic links go to OPS_NOTIFY_EMAIL.
# RESEND_API_KEY=
# RESEND_FROM=Oui Smoke <bookings@ouismoke.co>
OPS_NOTIFY_EMAIL=ouismokeinc@gmail.com
